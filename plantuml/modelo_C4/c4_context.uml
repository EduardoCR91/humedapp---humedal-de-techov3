@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Modelo C4 (Nivel 1) - Diagrama de Contexto del Sistema EcoVigia

Person(ciudadano, "Usuario Ciudadano", "Habitante o visitante de la localidad de Kennedy interesado en el monitoreo y resguardo del humedal.")
Person(administrador, "Colectivo / Administrador", "Encargado de la validación de reportes y de liderar jornadas de participación.")

System(ecovigia, "EcoVigia (Sistema Central)", "Aplicación móvil y plataforma base para el registro de denuncias ambientales, visualización de indicadores IoT y divulgación botánica/histórica.")

System_Ext(gemini, "API de Inteligencia Artificial", "Google Gemini. Provee las capacidades conversacionales para el chatbot ambiental (HumedBot).")
System_Ext(supabase, "Plataforma Backend (Supabase)", "Data warehouse externo operando sobre PostgreSQL que centraliza la identidad, mapas relacionales y bóveda de imágenes masivas.")
System_Ext(osm, "Proveedores de Cartografía", "OpenStreetMap (mediante Leaflet). Red remota de mapas base geográficos.")

Rel(ciudadano, ecovigia, "Reporta incidentes, fotografía aves y aprende iterativamente mediante", "Interfaz Móvil")
Rel(administrador, ecovigia, "Gestiona e incide políticamente basándose en", "Métricas del Sistema")

Rel(ecovigia, supabase, "Escribe y lee telemetría asíncrona, sincroniza usuarios con", "REST / WebSockets")
Rel(ecovigia, gemini, "Aumenta la educación generando prompts hacia", "HTTPS")
Rel(ecovigia, osm, "Carga mosaicos vectoriales topográficos desde", "HTTPS API")

@enduml
