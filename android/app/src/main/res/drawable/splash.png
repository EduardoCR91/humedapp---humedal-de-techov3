<svg width="800" height="480" viewBox="0 0 800 480" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="title desc">
  <title id="title">Fondo ilustrado de biodiversidad del humedal</title>
  <desc id="desc">
    Ilustración simple creada para EcoVigia! que representa agua, plantas y aves
    de manera abstracta, sin usar recursos con derechos de autor.
  </desc>
  <defs>
    <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#022c22"/>
      <stop offset="40%" stop-color="#065f46"/>
      <stop offset="100%" stop-color="#0ea5e9"/>
    </linearGradient>
    <linearGradient id="water" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#0f766e" stop-opacity="0.9"/>
      <stop offset="100%" stop-color="#22c55e" stop-opacity="0.7"/>
    </linearGradient>
  </defs>

  <!-- Cielo / fondo -->
  <rect width="800" height="480" fill="url(#sky)" />

  <!-- Sol -->
  <circle cx="640" cy="80" r="40" fill="#facc15" opacity="0.8" />

  <!-- Agua -->
  <path d="M0 320 Q200 290 400 320 T800 320 V480 H0 Z" fill="url(#water)" opacity="0.95" />
  <path d="M0 340 Q200 310 400 340 T800 340 V480 H0 Z" fill="#0ea5e9" opacity="0.5" />

  <!-- Totoras / plantas -->
  <g transform="translate(80,260)" fill="none" stroke="#bbf7d0" stroke-width="6" stroke-linecap="round">
    <path d="M0 120 Q20 40 10 0" />
    <path d="M30 120 Q40 60 35 10" />
    <path d="M60 120 Q70 50 65 0" />
    <circle cx="10" cy="0" r="8" fill="#22c55e" />
    <circle cx="35" cy="10" r="8" fill="#16a34a" />
    <circle cx="65" cy="0" r="8" fill="#4ade80" />
  </g>

  <g transform="translate(700,260)" fill="none" stroke="#bbf7d0" stroke-width="6" stroke-linecap="round">
    <path d="M0 120 Q-20 40 -10 0" />
    <path d="M-30 120 Q-40 60 -35 10" />
    <circle cx="-10" cy="0" r="8" fill="#22c55e" />
    <circle cx="-35" cy="10" r="8" fill="#16a34a" />
  </g>

  <!-- Aves estilizadas -->
  <g fill="none" stroke="#e5f9ff" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
    <path d="M220 120 q20 -20 40 0" />
    <path d="M220 120 q20 20 40 0" />
    <path d="M280 90 q18 -18 36 0" />
    <path d="M280 90 q18 18 36 0" />
    <path d="M340 140 q18 -18 36 0" />
    <path d="M340 140 q18 18 36 0" />
  </g>

  <!-- Ondas adicionales -->
  <g fill="none" stroke="#a5f3fc" stroke-width="3" opacity="0.6">
    <path d="M40 360 Q120 350 200 360 T360 360" />
    <path d="M420 370 Q500 360 580 370 T740 370" />
  </g>
</svg>
